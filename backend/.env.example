IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=

# AbacatePay (billing) — required in prod (set in the Railway dashboard);
# in dev the app boots with these empty, but checkout stays inoperative.
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# Base URL used in checkout return/completion redirects
# (dev default: http://localhost:5173)
APP_FRONTEND_BASE_URL=
