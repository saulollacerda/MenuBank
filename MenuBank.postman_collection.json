          }
        },
        {
          "name": "Update Order",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/orders/{{orderId}}",
              "host": ["{{base_url}}"],
