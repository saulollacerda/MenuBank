{
  "info": {
    "_postman_id": "menubank-collection-v1",
    "name": "MenuBank API",
    "description": "Collection completa da API do MenuBank — sistema de gestão financeira para restaurantes de delivery.\n\nPara começar:\n1. Configure o environment 'MenuBank Local'\n2. Execute 'Auth / Login' para obter o token (salvo automaticamente)\n3. As demais requisições já usam o token via variável {{token}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [],
  "item": [
    {
      "name": "Auth",
      "description": "Autenticação e registro de usuários.",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"restaurante@exemplo.com\",\n  \"password\": \"senha123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Autentica um usuário e retorna o token de acesso JWT. O token é salvo automaticamente na variável `token` do environment via script de teste."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    const token = json.token || json.accessToken || json.access_token;",
                  "    if (token) {",
                  "        pm.environment.set('token', token);",
                  "        console.log('Token salvo no environment.');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantName\": \"Meu Restaurante\",\n  \"cnpj\": \"12.345.678/0001-90\",\n  \"email\": \"restaurante@exemplo.com\",\n  \"password\": \"senha123\",\n  \"confirmPassword\": \"senha123\",\n  \"phone\": \"(11) 99999-9999\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Registra um novo usuário (restaurante) no sistema. Retorna o token de acesso JWT após o registro."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    const token = json.token || json.accessToken || json.access_token;",
                  "    if (token) {",
                  "        pm.environment.set('token', token);",
                  "        console.log('Token salvo no environment.');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Users",
      "description": "Gerenciamento de usuários do sistema.",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantName\": \"Meu Restaurante\",\n  \"cnpj\": \"12.345.678/0001-90\",\n  \"email\": \"restaurante@exemplo.com\",\n  \"password\": \"senha123\",\n  \"confirmPassword\": \"senha123\",\n  \"phone\": \"(11) 99999-9999\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Cria um novo usuário. Retorna 201 Created com os dados do usuário criado."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json.id) pm.environment.set('userId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/users/{{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{userId}}"]
            },
            "description": "Retorna os dados de um usuário pelo seu UUID. Substitua `{{userId}}` pelo ID real ou preencha a variável no environment."
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/users/{{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{userId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantName\": \"Restaurante Atualizado\",\n  \"cnpj\": \"12.345.678/0001-90\",\n  \"email\": \"novo@exemplo.com\",\n  \"password\": \"novaSenha123\",\n  \"confirmPassword\": \"novaSenha123\",\n  \"phone\": \"(11) 88888-8888\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Atualiza os dados de um usuário pelo seu UUID. Retorna 200 OK com os dados atualizados."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/users/{{userId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{userId}}"]
            },
            "description": "Remove um usuário pelo seu UUID. Retorna 204 No Content em caso de sucesso."
          }
        }
      ]
    },
