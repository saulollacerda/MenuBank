# ── Auth provider ────────────────────────────────────────────────────────────
# `local`    — dev sem Supabase: usa os endpoints /api/auth/dev-login e dev-register
#              (backend assina o JWT com a chave RSA local). Não requer Supabase.
# `supabase` — produção: autenticação delegada ao Supabase (default quando ausente).
VITE_AUTH_PROVIDER=local

# ── Supabase (apenas quando VITE_AUTH_PROVIDER=supabase) ─────────────────────
# Obtenha em Project Settings → API
VITE_SUPABASE_URL=https://<seu-projeto>.supabase.co
VITE_SUPABASE_ANON_KEY=<sua-anon-key>

# Base URL da API MenuBank (default: /api, proxied para http://localhost:8080 no dev)
VITE_API_BASE_URL=/api
